{
    "name": "@touchai/desktop",
    "private": true,
    "version": "1.2.0",
    "description": "Your desktop agent, one shortcut away.",
    "author": "TouchAI Team",
    "license": "GPL-3.0-or-later",
    "type": "module",
    "packageManager": "pnpm@10.32.1",
    "scripts": {
        "dev": "vite --configLoader runner",
        "build": "node ./scripts/run-node-command.mjs vue-tsc --noEmit && node ./scripts/run-node-command.mjs vite build --configLoader runner",
        "preview": "vite preview --configLoader runner",
        "tauri": "tauri",
        "test": "vitest --configLoader runner",
        "test:unit": "vitest run --configLoader runner --passWithNoTests",
        "test:coverage": "vitest run --configLoader runner --coverage --passWithNoTests",
        "test:e2e": "node ./scripts/run-e2e-command.mjs",
        "test:pr": "pnpm check && pnpm test:unit && pnpm test:rust && pnpm test:coverage",
        "test:rust": "node ./scripts/run-rust-command.mjs test",
        "test:coverage:rust": "cargo tarpaulin --manifest-path src-tauri/Cargo.toml --all-targets --branch --out xml",
        "test:typecheck": "node ./scripts/run-node-command.mjs vue-tsc -p tsconfig.vitest.json --noEmit",
        "test:ui": "vitest --configLoader runner --ui",
        "test:run": "pnpm test:unit",
        "type:check": "node ./scripts/run-node-command.mjs vue-tsc --noEmit",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "format:check": "prettier --check ../../apps/desktop --ignore-path ../../.prettierignore",
        "format:fix": "prettier --write ../../apps/desktop --ignore-path ../../.prettierignore && pnpm run format:rust:fix",
        "format:rust:fix": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
        "check:rust": "node ./scripts/run-rust-command.mjs check",
        "check": "pnpm type:check && pnpm test:typecheck && pnpm lint:check && pnpm format:check && cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check && pnpm check:rust",
        "db:generate": "drizzle-kit generate",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@ai-sdk/alibaba": "^1.0.29",
        "@ai-sdk/anthropic": "^3.0.85",
        "@ai-sdk/deepseek": "^2.0.39",
        "@ai-sdk/google": "^3.0.83",
        "@ai-sdk/moonshotai": "^2.0.26",
        "@ai-sdk/openai": "^3.0.73",
        "@ai-sdk/openai-compatible": "^2.0.51",
        "@ai-sdk/xai": "^3.0.96",
