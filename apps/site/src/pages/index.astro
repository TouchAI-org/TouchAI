                    height="109"
                    decoding="async"
                />
            </a>
            <div class="nav-actions">
                <a
                    class="nav-icon-link"
                    href={repoUrl}
                    target="_blank"
                    rel="noreferrer"
                    data-analytics-event="open_repository"
                    aria-label="GitHub"
                    title="GitHub"
                >
