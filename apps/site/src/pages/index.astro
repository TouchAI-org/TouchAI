---
import ComponentDemo from '../components/ComponentDemo.astro';

const CLARITY_ID = import.meta.env.PUBLIC_CLARITY_ID ?? '';
const WAITLIST_ENDPOINT = import.meta.env.PUBLIC_WAITLIST_ENDPOINT ?? '';
const ANALYTICS_ENDPOINT = import.meta.env.PUBLIC_ANALYTICS_ENDPOINT ?? '';
const siteUrl = 'https://touch-ai.org/';
const repoPath = 'TouchAI-org/TouchAI';
const repoUrl = `https://github.com/${repoPath}`;
const releasesUrl = `${repoUrl}/releases`;
const repoApiUrl = `https://api.github.com/repos/${repoPath}`;
const repoOpenIssuesApiUrl = `https://api.github.com/search/issues?q=${encodeURIComponent(
    `repo:${repoPath} is:issue is:open`
)}`;
const docsUrl = `${siteUrl}getting-started/`;
const titleZh = 'TouchAI：一触即达的桌面效率 Agent';
const titleEn = 'TouchAI: A Desktop Efficiency Agent at Your Fingertips';
const descriptionZh = '一触即达的桌面效率 Agent——随时待命，做您触手可及的 AI 入口';
const descriptionEn = 'Your desktop AI agent, always ready — your touch-accessible AI gateway';
const keywords =
    'TouchAI, desktop AI agent, AI desktop assistant, productivity agent, AI 助手, 桌面 AI, 桌面效率工具, 触控 AI, 自动化工作流, 本地桌面助手';
const socialImageUrl = `${siteUrl}seo-card.png`;
const organizationId = `${siteUrl}#organization`;
const websiteId = `${siteUrl}#website`;
const softwareId = `${siteUrl}#software`;
const loadInitialRepoStats = async () => {
    const headers = {
        Accept: 'application/vnd.github+json',
        'X-GitHub-Api-Version': '2022-11-28',
    };
    const stats = {
        stars: null,
        forks: null,
        issues: null,
    };

    try {
        const response = await fetch(repoApiUrl, { headers });
        if (response.ok) {
            const data = await response.json();
            stats.stars = data.stargazers_count;
            stats.forks = data.forks_count;
        }
    } catch {}

    try {
        const response = await fetch(repoOpenIssuesApiUrl, { headers });
        if (response.ok) {
            const data = await response.json();
            stats.issues = data.total_count;
        }
    } catch {}

    return stats;
};
const initialRepoStats = await loadInitialRepoStats();
const structuredData = JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'Organization',
            '@id': organizationId,
            name: 'TouchAI',
            url: siteUrl,
            logo: {
                '@type': 'ImageObject',
                url: `${siteUrl}logo.svg`,
            },
            sameAs: [repoUrl],
        },
        {
            '@type': 'WebSite',
            '@id': websiteId,
            url: siteUrl,
            name: 'TouchAI',
            alternateName: titleEn,
            description: descriptionZh,
            inLanguage: ['zh-CN', 'en'],
            publisher: {
                '@id': organizationId,
            },
        },
        {
            '@type': 'SoftwareApplication',
            '@id': softwareId,
            name: 'TouchAI',
            alternateName: 'TouchAI Desktop Agent',
            url: siteUrl,
            description: descriptionZh,
            applicationCategory: 'ProductivityApplication',
            applicationSubCategory: 'Desktop AI agent',
            operatingSystem: 'Windows 10/11, macOS 12+, Linux (Ubuntu 20.04+, Fedora 35+)',
            image: socialImageUrl,
            downloadUrl: releasesUrl,
            softwareHelp: docsUrl,
            mainEntityOfPage: siteUrl,
            inLanguage: ['zh-CN', 'en'],
            keywords,
            author: {
                '@id': organizationId,
            },
            publisher: {
                '@id': organizationId,
            },
            license: `${repoUrl}/blob/main/COPYING`,
            isAccessibleForFree: true,
            offers: {
                '@type': 'Offer',
                price: '0',
                priceCurrency: 'USD',
            },
        },
    ],
});
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
        <meta name="referrer" content="strict-origin-when-cross-origin" />
        <meta name="application-name" content="TouchAI" />
        <meta name="apple-mobile-web-app-title" content="TouchAI" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta name="mobile-web-app-capable" content="yes" />
        <meta name="format-detection" content="telephone=no, address=no, email=no" />
        <meta name="color-scheme" content="light dark" />
        <title
            id="site-title"
            data-zh={titleZh}
            data-en={titleEn}
        >
            {titleZh}
        </title>
        <meta
            id="site-description"
            name="description"
            content={descriptionZh}
            data-zh={descriptionZh}
            data-en={descriptionEn}
        />
        <meta name="keywords" content={keywords} />
        <meta name="author" content="TouchAI" />
        <meta name="theme-color" content="#ffffff" />
        <meta property="og:type" content="website" />
        <meta property="og:locale" content="zh_CN" />
        <meta property="og:locale:alternate" content="en_US" />
        <meta
            id="og-title"
            property="og:title"
            content={titleZh}
            data-zh={titleZh}
            data-en={titleEn}
        />
        <meta
            id="og-description"
            property="og:description"
            content={descriptionZh}
            data-zh={descriptionZh}
            data-en={descriptionEn}
        />
        <meta property="og:url" content={siteUrl} />
        <meta property="og:site_name" content="TouchAI" />
        <meta property="og:image" content={socialImageUrl} />
        <meta property="og:image:secure_url" content={socialImageUrl} />
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content="TouchAI desktop agent preview" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={siteUrl} />
        <meta
            id="twitter-title"
            name="twitter:title"
            content={titleZh}
            data-zh={titleZh}
            data-en={titleEn}
        />
        <meta
            id="twitter-description"
            name="twitter:description"
            content={descriptionZh}
            data-zh={descriptionZh}
            data-en={descriptionEn}
        />
        <meta name="twitter:image" content={socialImageUrl} />
        <meta name="twitter:image:alt" content="TouchAI desktop agent preview" />
        <link rel="canonical" href={siteUrl} />
        <link rel="alternate" hreflang="zh-CN" href={siteUrl} />
        <link rel="alternate" hreflang="en" href={siteUrl} />
        <link rel="alternate" hreflang="x-default" href={siteUrl} />
        <link rel="manifest" href="/site.webmanifest" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
        <link rel="preload" as="image" href="/touch-ai-hero-light.svg?v=3" type="image/svg+xml" />
        <script
            is:inline
            set:html={`(() => {
                try {
                    const storedTheme = localStorage.getItem('touchai-theme');
                    const nextTheme =
                        storedTheme === 'dark' || storedTheme === 'light'
                            ? storedTheme
                            : window.matchMedia('(prefers-color-scheme: dark)').matches
                              ? 'dark'
                              : 'light';
                    document.documentElement.dataset.theme = nextTheme;
                    document
                        .querySelector('meta[name="theme-color"]')
                        ?.setAttribute('content', nextTheme === 'dark' ? '#09090b' : '#ffffff');
                } catch {}
            })();`}
        />
        <script type="application/ld+json" set:html={structuredData} />
        {
            CLARITY_ID && (
                <script
                    is:inline
                    set:html={`(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src='https://www.clarity.ms/tag/'+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y)})(window,document,'clarity','script','${CLARITY_ID}');`}
                />
            )
        }
        <style is:global>
            :root {
                --bg: #ffffff;
                --ink: #111111;
                --muted: #5f5f5f;
                --line: #e4e4e7;
                --soft: #f4f4f5;
                --soft-2: #fffefa;
                --nav-bg: transparent;
                --dark: #101014;
                --feature-copy-surface: linear-gradient(180deg, #e9ebef 0%, #dfe3e8 100%);
                --feature-media-surface: linear-gradient(180deg, #fbfcfd 0%, #f1f3f6 100%);
                --feature-component-bg:
                    radial-gradient(circle at 18% 24%, rgba(74, 156, 255, 0.16), transparent 42%),
                    radial-gradient(circle at 78% 22%, rgba(255, 105, 180, 0.12), transparent 44%),
                    radial-gradient(circle at 52% 82%, rgba(255, 210, 92, 0.14), transparent 48%),
                    linear-gradient(135deg, #ffffff 0%, #f8fbff 50%, #fff8fb 100%);
                --feature-shell-bg: linear-gradient(132deg, #ffffff 0%, #fffefa 46%, #f3faff 100%);
                --component-stage-bg:
                    radial-gradient(circle at 19% 71%, rgba(74, 156, 255, 0.2), transparent 28%),
                    radial-gradient(circle at 72% 12%, rgba(74, 156, 255, 0.14), transparent 25%),
                    linear-gradient(132deg, #ffffff 0%, #fffefa 46%, #f3faff 100%);
                --max: 1180px;
                --font-serif:
                    'Source Han Serif SC', 'Source Han Serif CN', 'Noto Serif SC', 'Songti SC',
                    'SimSun', serif;
                --text-nav: 15px;
                --text-button: 15px;
                --text-caption: 15px;
                --text-body: 18px;
                --text-body-lg: 20px;
                --text-card-title: 27px;
            }

            html[data-theme='dark'] {
                --bg: #09090b;
                --ink: #fafafa;
                --muted: #a1a1aa;
                --line: #27272a;
                --soft: #18181b;
                --soft-2: #27272a;
                --nav-bg: transparent;
                --feature-copy-surface: linear-gradient(180deg, #2f3137 0%, #24262b 100%);
                --feature-media-surface: linear-gradient(180deg, #eef0f3 0%, #dfe3e8 100%);
                --feature-component-bg:
                    radial-gradient(circle at 18% 24%, rgba(74, 156, 255, 0.14), transparent 42%),
                    radial-gradient(circle at 78% 22%, rgba(255, 105, 180, 0.1), transparent 44%),
                    radial-gradient(circle at 52% 82%, rgba(255, 210, 92, 0.08), transparent 48%),
                    linear-gradient(135deg, #09090b 0%, #0d1118 50%, #120d14 100%);
                --feature-shell-bg: linear-gradient(132deg, #09090b 0%, #0a0b0f 52%, #0f1318 100%);
                --component-stage-bg:
                    radial-gradient(circle at 19% 71%, rgba(70, 86, 105, 0.14), transparent 29%),
                    radial-gradient(circle at 72% 12%, rgba(54, 68, 84, 0.1), transparent 25%),
                    linear-gradient(132deg, #09090b 0%, #0a0b0f 52%, #0f1318 100%);
                color-scheme: dark;
            }

            * {
                box-sizing: border-box;
            }

            [hidden] {
                display: none !important;
            }

            .sr-only {
                position: absolute;
                width: 1px;
                height: 1px;
                padding: 0;
                margin: -1px;
                overflow: hidden;
                clip: rect(0, 0, 0, 0);
                white-space: nowrap;
                border: 0;
            }

            html {
                scroll-behavior: auto;
            }

            section[id] {
                scroll-margin-top: 92px;
            }

            body {
                margin: 0;
                background: var(--bg);
                color: var(--ink);
                font-family: var(--font-serif);
                -webkit-font-smoothing: antialiased;
                text-rendering: optimizeLegibility;
                overflow-x: hidden;
            }

            a {
                color: inherit;
                text-decoration: none;
            }

            img {
                display: block;
                max-width: 100%;
            }

            .nav {
                position: sticky;
                top: 0;
                z-index: 20;
                display: grid;
                grid-template-columns: 1fr 1fr;
                align-items: center;
                width: 100%;
                min-height: 72px;
                margin: 0 auto;
                padding: 0 24px;
                background: var(--nav-bg);
                backdrop-filter: none;
                transition:
                    background-color 0.2s ease,
                    box-shadow 0.2s ease,
                    backdrop-filter 0.2s ease;
            }

            .nav::after {
                content: '';
                position: absolute;
                left: 0;
                right: 0;
                bottom: -24px;
                height: 24px;
                pointer-events: auto;
                opacity: 0;
                background: linear-gradient(
                    180deg,
                    rgba(255, 255, 255, 0.28) 0%,
                    rgba(255, 255, 255, 0) 100%
                );
                transition: opacity 0.2s ease;
            }

            .nav.is-scrolled {
                background: rgba(255, 255, 255, 0.94);
                backdrop-filter: blur(14px);
                box-shadow: none;
            }

            html[data-theme='dark'] .nav.is-scrolled {
                background: rgba(9, 9, 11, 0.94);
            }

            html[data-theme='dark'] .nav::after {
                background: linear-gradient(
                    180deg,
                    rgba(9, 9, 11, 0.72) 0%,
                    rgba(9, 9, 11, 0) 100%
                );
            }

            .nav.is-scrolled::after {
                opacity: 1;
            }

            .logo-link {
                display: inline-flex;
                align-items: center;
                justify-self: start;
                justify-content: flex-start;
                width: max-content;
            }

            .wordmark {
                width: 150px;
                height: auto;
            }

            html[data-theme='dark'] .wordmark {
                content: url('/touchai-wordmark-light.svg');
            }

            .nav-actions {
                display: flex;
                align-items: center;
                gap: 26px;
                font-size: var(--text-nav);
                font-weight: 600;
                line-height: 1;
            }

            .nav-actions {
                justify-content: flex-end;
            }

            .nav-icon-link {
                width: 28px;
                height: 28px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                transition: transform 0.16s ease;
                will-change: transform;
            }

            .nav-icon-link svg {
                width: 20px;
                height: 20px;
                stroke-width: 1.9;
            }

            .lang-toggle {
                position: relative;
                width: 28px;
                height: 28px;
                border: 0;
                padding: 0;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 0;
                color: var(--ink);
                background: transparent;
                font: inherit;
                font-weight: 600;
                line-height: 1;
                cursor: pointer;
                transition: transform 0.16s ease;
                will-change: transform;
            }

            .theme-toggle {
                width: 28px;
                height: 28px;
                border: 0;
                padding: 0;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                color: var(--ink);
                background: transparent;
                cursor: pointer;
                transition: transform 0.16s ease;
                will-change: transform;
            }

            .theme-toggle svg {
                width: 20px;
                height: 20px;
                stroke-width: 1.9;
            }

            .theme-toggle .sun-icon {
                display: none;
            }

            html[data-theme='dark'] .theme-toggle .moon-icon {
                display: none;
            }

            html[data-theme='dark'] .theme-toggle .sun-icon {
                display: block;
            }

            .lang-toggle svg {
                width: 18px;
                height: 18px;
                stroke-width: 1.8;
            }

            .lang-toggle span {
                position: absolute;
                width: 1px;
                height: 1px;
                overflow: hidden;
                clip: rect(0, 0, 0, 0);
                white-space: nowrap;
            }

            .lang-toggle:hover,
            .theme-toggle:hover {
                text-decoration: underline;
                text-underline-offset: 5px;
            }

            .nav a:hover {
                text-decoration: underline;
                text-underline-offset: 5px;
            }

            .hero {
                position: relative;
                isolation: isolate;
                overflow: hidden;
                width: 100%;
                max-width: none;
                margin: 0;
                min-height: calc(100dvh - 72px);
                padding: 32px 24px 40px;
                display: flex;
                flex-direction: column;
                justify-content: center;
                text-align: center;
                background: var(--bg);
                background-image: none;
            }

            .hero::before,
            .hero::after {
                content: none !important;
                display: none !important;
            }

            .hero h1 {
                margin: 0;
                line-height: 1;
            }

            .hero-wordmark {
                width: min(72vw, 640px);
                height: auto;
                margin: 0 auto;
            }

            html[data-theme='dark'] .hero-wordmark {
                content: url('/touch-ai-hero-dark.svg?v=3');
            }

            .hero-subtitle {
                max-width: 820px;
                margin: 24px auto 0;
                color: var(--ink);
                font-size: clamp(28px, 3.1vw, 42px);
                font-weight: 500;
                line-height: 1.22;
                letter-spacing: 0;
            }

            .hero-actions {
                display: flex;
                flex-wrap: wrap;
                justify-content: center;
                gap: 14px;
                margin-top: 28px;
            }

            .button {
                position: relative;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-height: 46px;
                padding: 0 22px;
                border: 1px solid var(--ink);
                border-radius: 999px;
                background: var(--ink);
                color: var(--bg);
                font-family: var(--font-serif);
                font-size: var(--text-button);
                font-weight: 600;
                line-height: 1;
                white-space: nowrap;
                overflow: hidden;
                transition:
                    background 0.2s ease,
                    color 0.2s ease,
                    border-color 0.2s ease,
                    transform 0.16s ease;
                will-change: transform;
            }

            .interactive-click {
                position: relative;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                overflow: hidden;
                isolation: isolate;
                transition:
                    color 0.2s ease,
                    background 0.2s ease,
                    border-color 0.2s ease,
                    transform 0.16s ease;
                will-change: transform;
            }

            .logo-link.interactive-click {
                justify-content: flex-start;
                width: max-content;
            }

            .nav-icon-link,
            .lang-toggle,
            .theme-toggle {
                position: relative;
                overflow: hidden;
                border-radius: 999px;
            }

            .interactive-click > * {
                position: relative;
                z-index: 1;
            }

            .button:hover {
                transform: translateY(-1px);
            }

            .interactive-click.is-pressing {
                transform: scale(0.94);
            }

            .button.secondary {
                background: var(--bg);
                color: var(--ink);
            }

            .glimm-click-layer {
                position: fixed;
                inset: 0;
                z-index: 9999;
                width: 100vw;
                height: 100vh;
                pointer-events: auto;
            }

            body.is-glimm-transitioning .interactive-click {
                pointer-events: auto;
            }

            .visual-section {
                width: min(calc(100% - 48px), var(--max));
                margin: 0 auto;
                min-height: max(380svh, 3200px);
            }

            .visual-shell {
                position: sticky;
                top: 0;
                overflow: hidden;
                border-radius: 14px;
                background: var(--bg);
                box-shadow: none;
                height: 100svh;
                min-height: 100svh;
                display: grid;
                align-items: center;
            }

            .visual-stage {
                width: 100%;
                height: 100svh;
                min-height: 780px;
                background: var(--bg);
                display: grid;
                align-items: center;
                justify-items: center;
                overflow: visible;
            }

            .visual-shell,
            .visual-stage,
            .component-frame {
                transition: background-color 0.2s ease;
            }

            .visual-stage-inner {
                width: 100%;
                height: 100%;
            }

            touchai-component-demo {
                --page-bg: var(--component-stage-bg);
            }

            .component-frame {
                --page-bg: transparent;
                display: block;
                width: min(60vw, 680px, 100%);
                max-width: 680px;
                height: 100%;
                min-height: 0;
                border: 0;
                background: transparent;
                justify-self: center;
            }

            .section {
                width: min(calc(100% - 48px), var(--max));
                margin: 0 auto;
                padding: 92px 0;
            }

            .section-title {
                max-width: 900px;
                margin: 0 0 46px;
                font-size: clamp(38px, 5.8vw, 72px);
                font-weight: 600;
                line-height: 1.12;
                letter-spacing: 0;
            }

            .feature-stack {
                display: grid;
                gap: 20px;
            }

            .feature-block {
                position: relative;
                min-height: clamp(1500px, 220vh, 2100px);
            }

            .feature-block-shell {
                position: sticky;
                top: calc(50vh - 280px);
                display: grid;
                grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
                min-height: 560px;
                overflow: visible;
                border-radius: 28px;
                background: transparent;
                align-items: stretch;
            }

            .feature-block.reverse .feature-block-shell {
                grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
            }

            .feature-copy {
                display: flex;
                flex-direction: column;
                justify-content: center;
                gap: 38px;
                padding: clamp(24px, 4vw, 40px);
                min-height: 560px;
                background: var(--feature-copy-surface);
                overflow: hidden;
            }

            .feature-block .feature-copy:first-child,
            .feature-block .feature-media:first-child {
                border-radius: 28px 0 0 28px;
            }

            .feature-block .feature-copy:last-child,
            .feature-block .feature-media:last-child {
                border-radius: 0 28px 28px 0;
            }

            .feature-copy h3 {
                width: 100%;
                max-width: 500px;
                margin: 0;
                font-size: clamp(28px, 3.5vw, 44px);
                font-weight: 600;
                line-height: 1.18;
                text-align: left;
                letter-spacing: 0;
            }

            .feature-copy p {
                width: 100%;
                max-width: 500px;
                margin: 0;
                color: var(--muted);
                font-size: var(--text-body);
                line-height: 1.7;
                text-align: justify;
                text-align-last: left;
                letter-spacing: 0;
            }

            html[lang='en'] .feature-copy p {
                text-align: left;
            }

            .feature-media {
                display: grid;
                place-items: center;
                min-height: 560px;
                padding: 18px;
                background: var(--feature-media-surface);
                overflow: visible;
            }

            .feature-media.solver-media {
                padding: 0;
            }

            .feature-media.work-media,
            .feature-media.reminder-media {
                padding: 0;
            }

            .feature-block.reverse .feature-copy {
                background: var(--feature-media-surface);
                color: #111111;
            }

            .feature-block.reverse .feature-copy p {
                color: #5f6368;
            }

            .feature-block.reverse .feature-media {
                background: var(--feature-copy-surface);
            }

            .phone-card,
            .code-card {
                width: min(100%, 520px);
                border: 0;
                border-radius: 18px;
                background: transparent;
                box-shadow: none;
                overflow: hidden;
            }

            .feature-component-card {
                --component-scale: 1;
                --component-shell-height: 657px;
                --embedded-frame-height: var(--component-shell-height);
                --page-bg: transparent;
