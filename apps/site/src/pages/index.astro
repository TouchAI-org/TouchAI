            .scenario-grid {
                display: grid;
                grid-template-columns: repeat(3, minmax(0, 1fr));
                gap: 16px;
                perspective: 1100px;
            }

            .scenario-card {
                position: relative;
                min-height: 360px;
                padding: 28px;
                border-radius: 28px;
                background: #eeece6;
                color: #151515;
                overflow: hidden;
                transform-style: preserve-3d;
                will-change: transform, opacity;
                transition:
                    background-color 0.28s ease,
                    color 0.28s ease,
                    box-shadow 0.28s ease;
            }

            html[data-theme='dark'] .scenario-card {
                background: #eeece6;
                color: #151515;
            }

            .scenario-grid .scenario-card:hover {
                background: #eeece6;
                color: #151515;
                box-shadow: 0 18px 42px rgba(0, 0, 0, 0.22);
            }

            .scenario-grid:hover .scenario-card:not(:hover) {
                background: #eeece6;
                color: #151515;
                box-shadow: none;
            }

            html[data-theme='dark'] .scenario-grid .scenario-card:hover {
                background: #eeece6;
                color: #151515;
                box-shadow: 0 18px 42px rgba(0, 0, 0, 0.22);
            }

            html[data-theme='dark'] .scenario-grid:hover .scenario-card:not(:hover) {
                background: #eeece6;
                color: #151515;
                box-shadow: none;
            }

            .scenario-card::before {
                content: '';
                position: absolute;
                inset: -1px;
                z-index: 0;
                border-radius: inherit;
                opacity: var(--scenario-glow-opacity, 0);
                background:
                    radial-gradient(
                        circle at var(--scenario-glow-x, 50%) var(--scenario-glow-y, 50%),
                        rgba(118, 179, 255, 0.34),
                        transparent 34%
                    ),
                    linear-gradient(135deg, rgba(255, 255, 255, 0.22), transparent 42%);
                transition: opacity 0.24s ease;
                pointer-events: none;
            }

            .scenario-card::after {
                content: '';
                position: absolute;
                inset: 0;
                z-index: 0;
                border-radius: inherit;
                opacity: var(--scenario-shine-opacity, 0);
                background: linear-gradient(
                    110deg,
                    transparent 0%,
                    rgba(255, 255, 255, 0.34) 43%,
                    rgba(255, 255, 255, 0.12) 50%,
                    transparent 58%
                );
                transform: translateX(var(--scenario-shine-x, -120%));
                pointer-events: none;
            }

            .scenario-card > * {
                position: relative;
                z-index: 1;
            }

            .scenario-card h3 {
                margin: 0 0 18px;
                font-size: var(--text-card-title);
