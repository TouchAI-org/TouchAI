                    },
                };

                const featureProgressByFrame = new WeakMap();
                const lastDispatchedDemoProgress = new WeakMap();
                const pendingDemoProgress = new WeakMap();
                const demoProgressFrameHandles = new WeakMap();
                const snapDemoProgress = (value) => {
                    const numericValue = Number(value);
                    const clampedValue = Number.isFinite(numericValue)
                        ? Math.min(1, Math.max(0, numericValue))
                        : 0;

                    if (clampedValue <= 0) return 0;
                    if (clampedValue >= 1) return 1;

                    return Math.round(clampedValue * 240) / 240;
                };
                const cancelQueuedDemoProgress = (frame) => {
                    if (!frame) return;
                    const frameHandle = demoProgressFrameHandles.get(frame);
                    if (frameHandle) {
                        cancelAnimationFrame(frameHandle);
                        demoProgressFrameHandles.delete(frame);
                    }
                    pendingDemoProgress.delete(frame);
                };
                const queueDemoProgress = (frame, type, progress, force = false) => {
                    if (!frame) return;

                    const snappedProgress = snapDemoProgress(progress);
                    const lastProgress = lastDispatchedDemoProgress.get(frame);
                    if (!force && lastProgress === snappedProgress) return;

                    pendingDemoProgress.set(frame, {
                        type,
                        progress: snappedProgress,
                        force,
                    });

                    if (demoProgressFrameHandles.has(frame)) return;

                    const frameHandle = requestAnimationFrame(() => {
                        demoProgressFrameHandles.delete(frame);
                        const nextProgress = pendingDemoProgress.get(frame);
                        if (!nextProgress) return;

                        pendingDemoProgress.delete(frame);
                        const dispatchedProgress = lastDispatchedDemoProgress.get(frame);
                        if (!nextProgress.force && dispatchedProgress === nextProgress.progress) {
                            return;
                        }

                        lastDispatchedDemoProgress.set(frame, nextProgress.progress);
                        sendToDemo(frame, {
                            type: nextProgress.type,
                            progress: nextProgress.progress,
                        });
                    });

                    demoProgressFrameHandles.set(frame, frameHandle);
                };
                const queueDemoScrollIdle = (frame) => {
                    if (!frame) return;
                    requestAnimationFrame(() => {
                        sendToDemo(frame, { type: 'touchai-clear-scroll-driven' });
                    });
                };
                function syncFeatureDemoProgress(frame, progress, force = false) {
                    if (!frame) return;
                    const mappedProgress = Math.min(1, Math.max(0, Number(progress) || 0));
                    const snappedProgress = snapDemoProgress(mappedProgress);
                    featureProgressByFrame.set(frame, snappedProgress);
                    queueDemoProgress(
                        frame,
                        'touchai-set-scroll-progress',
                        snappedProgress,
                        force
                    );
                }

                function restoreFeatureDemoProgress(frame) {
                    if (!frame) return;
                    const progress = featureProgressByFrame.get(frame) ?? 0;
                    syncFeatureDemoProgress(frame, progress, true);
                    window.setTimeout(() => syncFeatureDemoProgress(frame, progress, true), 120);
                    window.setTimeout(() => syncFeatureDemoProgress(frame, progress, true), 360);
                }

                const setLanguage = (language) => {
                    const lang = language === 'en' ? 'en' : 'zh';
                    document.documentElement.lang = lang === 'en' ? 'en' : 'zh-CN';
                    const localizedHeadNodes = document.querySelectorAll(
                        '#site-title, #site-description, #og-title, #og-description, #twitter-title, #twitter-description'
                    );
                    localizedHeadNodes.forEach((node) => {
                        const value = node.getAttribute(`data-${lang}`);
                        if (!value) return;
                        if (node.tagName === 'TITLE') {
                            node.textContent = value;
                            return;
                        }
                        node.setAttribute('content', value);
                    });
                    document
                        .querySelector('meta[property="og:locale"]')
                        ?.setAttribute('content', lang === 'en' ? 'en_US' : 'zh_CN');
                    document
                        .querySelector('meta[property="og:locale:alternate"]')
                        ?.setAttribute('content', lang === 'en' ? 'zh_CN' : 'en_US');
                    document.querySelectorAll('[data-i18n]').forEach((node) => {
                        const key = node.dataset.i18n;
                        if (key && translations[lang][key]) {
                            node.textContent = translations[lang][key];
                        }
                    });
                    const toggle = document.querySelector('.lang-toggle');
                    if (toggle) {
                        toggle.setAttribute('aria-pressed', String(lang === 'en'));
                        toggle.setAttribute(
                            'aria-label',
                            lang === 'en' ? '切换到中文' : 'Switch to English'
                        );
                        toggle.setAttribute(
                            'title',
                            lang === 'en' ? '切换到中文' : 'Switch to English'
                        );
                        toggle.querySelector('span').textContent = lang === 'en' ? 'EN' : '中';
                    }
                    const introDemo = document.querySelector('.component-frame');
                    if (introDemo) {
                        const nextSrc =
                            lang === 'en'
                                ? '/touchai-intro-en/touchai-components.html?v=1'
                                : '/touchai-intro/touchai-components.html?v=8';
                        if (introDemo.dataset.src !== nextSrc) {
                            introDemo.dataset.src = nextSrc;
                            introDemo.dataset.title =
                                lang === 'en'
                                    ? 'TouchAI intro component demo'
                                    : 'TouchAI 介绍组件演示';
                            Promise.resolve(introDemo.reload?.()).then(() => {
                                syncComponentBackground();
                            });
                        }
                    }
                    const solverDemo = document.querySelector('.feature-component-frame');
                    if (solverDemo) {
                        const nextSolverSrc =
                            lang === 'en'
                                ? '/feature-solver-en/touchai-components.html?v=1'
                                : '/feature-solver/touchai-components.html?v=17';
                        if (solverDemo.dataset.src !== nextSolverSrc) {
                            solverDemo.dataset.src = nextSolverSrc;
                            solverDemo.dataset.title =
                                lang === 'en'
                                    ? 'TouchAI math solver component demo'
                                    : 'TouchAI 解题组件演示';
                            Promise.resolve(solverDemo.reload?.()).then(() => {
                                syncComponentBackground();
                                restoreFeatureDemoProgress(solverDemo);
                            });
                        }
                    }
                    const workDemo = document.querySelector('.feature-work-frame');
                    if (workDemo) {
                        const nextWorkSrc =
                            lang === 'en'
                                ? '/feature-work-organizer-en/touchai-components.html?v=1'
                                : '/feature-work-organizer/touchai-components.html?v=13';
                        if (workDemo.dataset.src !== nextWorkSrc) {
                            workDemo.dataset.src = nextWorkSrc;
                            workDemo.dataset.title =
                                lang === 'en'
                                    ? 'TouchAI work organizer component demo'
                                    : 'TouchAI 工作整理组件演示';
                            Promise.resolve(workDemo.reload?.()).then(() => {
                                syncComponentBackground();
                                restoreFeatureDemoProgress(workDemo);
                            });
                        }
                    }
                    const reminderDemo = document.querySelector('.feature-reminder-frame');
                    if (reminderDemo) {
                        const nextReminderSrc =
                            lang === 'en'
                                ? '/feature-reminder-en/touchai-components.html?v=1'
                                : '/feature-reminder/touchai-components.html?v=5';
                        if (reminderDemo.dataset.src !== nextReminderSrc) {
                            reminderDemo.dataset.src = nextReminderSrc;
                            reminderDemo.dataset.title =
                                lang === 'en'
                                    ? 'TouchAI meeting reminder component demo'
                                    : 'TouchAI MCP 工具调用组件演示';
                            Promise.resolve(reminderDemo.reload?.()).then(() => {
                                syncComponentBackground();
                                restoreFeatureDemoProgress(reminderDemo);
                            });
                        }
                    }
                    localStorage.setItem('touchai-language', lang);
                };

                const languageToggle = document.querySelector('.lang-toggle');
                const savedLanguage = localStorage.getItem('touchai-language');
                setLanguage(savedLanguage === 'en' ? 'en' : 'zh');

                const analyticsEndpoint = document.body.dataset.analyticsEndpoint?.trim();
                let hasTrackedPageView = false;
                const sendAnalytics = (type, detail = {}) => {
                    if (!analyticsEndpoint) return;
                    const payload = JSON.stringify({
                        type,
                        href: window.location.href,
                        path: window.location.pathname,
                        title: document.title,
                        lang: document.documentElement.lang,
                        referrer: document.referrer || '',
                        viewport: `${window.innerWidth}x${window.innerHeight}`,
                        ts: new Date().toISOString(),
                        ...detail,
                    });

                    try {
                        if (navigator.sendBeacon) {
                            const sent = navigator.sendBeacon(
                                analyticsEndpoint,
                                new Blob([payload], { type: 'application/json' })
                            );
                            if (sent) return;
                        }
                    } catch (_error) {
                        // Fall through to fetch.
                    }

                    fetch(analyticsEndpoint, {
                        method: 'POST',
                        headers: { 'content-type': 'application/json' },
                        body: payload,
                        keepalive: true,
                    }).catch(() => {});
                };
                const trackPageView = () => {
                    if (hasTrackedPageView) return;
                    hasTrackedPageView = true;
                    sendAnalytics('pageview');
                };

                if (document.readyState === 'complete') {
                    queueMicrotask(trackPageView);
                } else {
                    window.addEventListener('load', trackPageView, { once: true });
                }

                document.querySelectorAll('[data-analytics-event]').forEach((node) => {
                    node.addEventListener('click', () => {
                        sendAnalytics(node.dataset.analyticsEvent, {
                            label: node.getAttribute('aria-label') || node.textContent?.trim() || '',
                        });
                    });
                });

                const componentBackgroundFrames = () =>
                    document.querySelectorAll('touchai-component-demo');

                const syncFeatureFrameSizing = () => {
                    [
                        ['.feature-component-card', '.feature-component-frame'],
                        ['.feature-work-card', '.feature-work-frame'],
                        ['.feature-reminder-card', '.feature-reminder-frame'],
                    ].forEach(([cardSelector, frameSelector]) => {
                        const card = document.querySelector(cardSelector);
                        const frame = document.querySelector(frameSelector);
                        if (!frame) return;

                        if (card) {
                            const width = card.getBoundingClientRect().width || 0;
                            if (width > 0) {
                                card.style.setProperty('--component-scale', String(width / 760));
                            }
                        }

                        frame.style.height = '657px';
                        frame.style.minHeight = '657px';
                        frame.style.maxHeight = '657px';
                        frame.style.background = 'transparent';
                    });
                };

                const syncComponentBackground = () => {
                    requestAnimationFrame(() => {
                        const componentStageBg = getComputedStyle(document.documentElement)
                            .getPropertyValue('--component-stage-bg')
                            .trim();
                        componentBackgroundFrames().forEach((frame) => {
                            const isSolverFrame =
                                frame.classList.contains('feature-component-frame');
                            const isFeatureFrame =
                                isSolverFrame ||
                                frame.classList.contains('feature-work-frame') ||
                                frame.classList.contains('feature-reminder-frame');
                            const isIntroFrame = frame.classList.contains('component-frame');
                            const nextBg = isIntroFrame
                                ? 'transparent'
                                : isFeatureFrame
                                  ? 'transparent'
                                  : componentStageBg;
                            frame.style.setProperty('--page-bg', nextBg);
                            frame.style.background = 'transparent';
                            sendToDemo(frame, { type: 'touchai-page-bg', background: nextBg });
                        });
                        syncFeatureFrameSizing();
                    });
                };

                const setTheme = (theme) => {
                    const nextTheme = theme === 'dark' ? 'dark' : 'light';
                    document.documentElement.dataset.theme = nextTheme;
                    document
                        .querySelector('meta[name="theme-color"]')
                        ?.setAttribute('content', nextTheme === 'dark' ? '#101014' : '#ffffff');
                    const themeToggle = document.querySelector('.theme-toggle');
                    if (themeToggle) {
                        themeToggle.setAttribute('aria-pressed', String(nextTheme === 'dark'));
                        themeToggle.setAttribute(
                            'aria-label',
                            nextTheme === 'dark' ? '切换白天模式' : '切换黑夜模式'
                        );
                        themeToggle.setAttribute(
                            'title',
                            nextTheme === 'dark' ? '切换白天模式' : '切换黑夜模式'
                        );
                    }
                    localStorage.setItem('touchai-theme', nextTheme);
                    syncComponentBackground();
                };

                const githubStatsGroup = document.querySelector('.github-stats');
                const REPO_STATS_SOURCE =
                    githubStatsGroup?.dataset.repoPath || 'TouchAI-org/TouchAI';
                const REPO_STATS_API_URL =
                    githubStatsGroup?.dataset.repoApiUrl ||
                    `https://api.github.com/repos/${REPO_STATS_SOURCE}`;
                const REPO_OPEN_ISSUES_API_URL =
                    githubStatsGroup?.dataset.repoOpenIssuesApiUrl ||
                    `https://api.github.com/search/issues?q=${encodeURIComponent(
                        `repo:${REPO_STATS_SOURCE} is:issue is:open`
                    )}`;
                const REPO_STATS_STORAGE_KEY = `touchai-github-stats:${REPO_STATS_SOURCE}`;
                const REPO_STATS_REFRESH_INTERVAL = 5 * 60 * 1000;
                const REPO_STATS_REFOCUS_INTERVAL = 90 * 1000;
                const REPO_STATS_REQUEST_GAP = 20 * 1000;
                const repoStats = {
                    stars: 0,
                    forks: 0,
                    issues: 0,
                    updatedAt: 0,
                };
                const statNodes = {
                    stars: document.querySelector('[data-github-stat="stars"]'),
                    forks: document.querySelector('[data-github-stat="forks"]'),
                    issues: document.querySelector('[data-github-stat="issues"]'),
                };
                const statFormatter = new Intl.NumberFormat('en-US');
                const normalizeStat = (value) => {
                    const num = Number(value);
                    return Number.isFinite(num) && num >= 0 ? Math.round(num) : null;
                };
                const formatStat = (value) => {
                    const num = normalizeStat(value);
                    return num == null ? '--' : statFormatter.format(num);
                };
                const readInitialRepoStats = () => ({
                    stars: normalizeStat(githubStatsGroup?.dataset.initialStars),
                    forks: normalizeStat(githubStatsGroup?.dataset.initialForks),
                    issues: normalizeStat(githubStatsGroup?.dataset.initialIssues),
                    updatedAt: 0,
                });
                const setRepoStatsLoading = (loading) => {
                    Object.values(statNodes).forEach((node) => {
                        if (!node) return;
                        node.dataset.loading = loading ? 'true' : 'false';
                    });
                    if (githubStatsGroup) {
                        githubStatsGroup.setAttribute('aria-busy', loading ? 'true' : 'false');
                    }
                };
                const renderRepoStats = (nextStats, { loading = false } = {}) => {
                    if (statNodes.stars) statNodes.stars.textContent = formatStat(nextStats.stars);
                    if (statNodes.forks) statNodes.forks.textContent = formatStat(nextStats.forks);
                    if (statNodes.issues) statNodes.issues.textContent = formatStat(nextStats.issues);
                    setRepoStatsLoading(loading);
                };
                const loadStoredRepoStats = () => {
                    try {
                        const raw = localStorage.getItem(REPO_STATS_STORAGE_KEY);
                        if (!raw) return null;
                        const parsed = JSON.parse(raw);
                        const nextStats = {
                            stars: normalizeStat(parsed?.stars),
                            forks: normalizeStat(parsed?.forks),
                            issues: normalizeStat(parsed?.issues),
                            updatedAt: Number(parsed?.updatedAt) || 0,
                        };
                        const hasValidStats = ['stars', 'forks', 'issues'].every(
                            (key) => nextStats[key] != null
                        );
                        return hasValidStats
                            ? nextStats
                            : null;
                    } catch (error) {
                        return null;
                    }
                };
                const persistRepoStats = (nextStats) => {
                    try {
                        localStorage.setItem(
                            REPO_STATS_STORAGE_KEY,
                            JSON.stringify({
                                stars: normalizeStat(nextStats.stars),
                                forks: normalizeStat(nextStats.forks),
                                issues: normalizeStat(nextStats.issues),
                                updatedAt: Number(nextStats.updatedAt) || Date.now(),
                            })
                        );
                    } catch (error) {}
                };
                const shouldRefreshRepoStats = (minAge = 0) =>
                    Date.now() - repoStats.updatedAt >= minAge;
                const withCacheBuster = (url) =>
                    `${url}${url.includes('?') ? '&' : '?'}ts=${Date.now()}`;
                const fetchRepoOverview = async () => {
                    const headers = {
                        Accept: 'application/vnd.github+json',
                        'X-GitHub-Api-Version': '2022-11-28',
                    };
                    const [repoResponse, openIssuesResponse] = await Promise.all([
                        fetch(withCacheBuster(REPO_STATS_API_URL), {
                            cache: 'no-store',
                            headers,
                        }),
                        fetch(withCacheBuster(REPO_OPEN_ISSUES_API_URL), {
                            cache: 'no-store',
                            headers,
                        }),
                    ]);
                    if (!repoResponse.ok || !openIssuesResponse.ok) {
                        throw new Error('repo stats request failed');
                    }
                    const [repoData, openIssuesData] = await Promise.all([
                        repoResponse.json(),
                        openIssuesResponse.json(),
                    ]);
                    return {
                        stars: normalizeStat(repoData.stargazers_count),
                        forks: normalizeStat(repoData.forks_count),
                        issues: normalizeStat(openIssuesData.total_count),
                    };
                };
                let repoStatsRequest = null;
                let lastRepoStatsRequestAt = 0;
                const refreshRepoStats = async ({ force = false } = {}) => {
                    const now = Date.now();
                    if (repoStatsRequest) return repoStatsRequest;
                    if (!force && now - lastRepoStatsRequestAt < REPO_STATS_REQUEST_GAP) return null;
                    if (!force && document.hidden && repoStats.updatedAt > 0) return null;

                    lastRepoStatsRequestAt = now;
                    renderRepoStats(repoStats, { loading: true });

                    repoStatsRequest = fetchRepoOverview()
                        .then((nextStats) => {
                            const mergedStats = { ...repoStats, ...nextStats };
                            const hasValidStats = ['stars', 'forks', 'issues'].every(
                                (key) => normalizeStat(mergedStats[key]) != null
                            );
                            if (!hasValidStats) return;
                            Object.assign(repoStats, mergedStats, {
                                updatedAt: Date.now(),
                            });
                            persistRepoStats(repoStats);
                        })
                        .catch(() => {})
                        .finally(() => {
                            repoStatsRequest = null;
                            renderRepoStats(repoStats);
                        });

                    return repoStatsRequest;
                };

                const savedTheme = localStorage.getItem('touchai-theme');
                const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                setTheme(savedTheme || (prefersDark ? 'dark' : 'light'));
                Object.assign(repoStats, readInitialRepoStats());
                const storedRepoStats = loadStoredRepoStats();
                if (storedRepoStats) Object.assign(repoStats, storedRepoStats);
                renderRepoStats(repoStats);
                refreshRepoStats({ force: true });
                window.setInterval(() => {
                    refreshRepoStats();
                }, REPO_STATS_REFRESH_INTERVAL);
                document.addEventListener('visibilitychange', () => {
                    if (!document.hidden && shouldRefreshRepoStats(REPO_STATS_REFOCUS_INTERVAL)) {
                        refreshRepoStats({ force: true });
                    }
                });
                window.addEventListener('focus', () => {
                    if (shouldRefreshRepoStats(REPO_STATS_REFOCUS_INTERVAL)) {
                        refreshRepoStats({ force: true });
                    }
                });
                window.addEventListener('online', () => {
                    refreshRepoStats({ force: true });
                });

                componentBackgroundFrames().forEach((frame) => {
                    frame.addEventListener('load', syncComponentBackground);
                    frame.addEventListener('touchai-component-loaded', syncComponentBackground);
                });
                syncFeatureFrameSizing();

                let glimmCanvas = null;
                let glimmController = null;
                let glimmUnavailable = false;

                const ensureGlimmController = () => {
                    if (glimmController || glimmUnavailable) return glimmController;

                    glimmCanvas = document.createElement('canvas');
                    glimmCanvas.className = 'glimm-click-layer';
                    glimmCanvas.setAttribute('aria-hidden', 'true');
                    document.body.appendChild(glimmCanvas);

                    try {
                        glimmController = createShader({
                            canvas: glimmCanvas,
                            palette: 'berry',
                            direction: 'ltr',
                            bandTight: 0.78,
                            brightness:
                                document.documentElement.dataset.theme === 'dark' ? 1.26 : 1.48,
                            waveAmount: 1.34,
                            rippleAmount: 1.24,
                            waveSpeed: 1.16,
                            swellAmount: 1.1,
                        });
                    } catch (error) {
                        glimmUnavailable = true;
                        glimmCanvas.remove();
                        glimmCanvas = null;
                    }

                    return glimmController;
                };

                let activeGlimmSweep = null;
                const playGlimmSweep = (midpointAction, options = {}) => {
                    const controller = ensureGlimmController();
                    if (!controller) {
                        midpointAction?.();
                        return Promise.resolve();
                    }
                    activeGlimmSweep?.cancel?.();
                    document.body.classList.add('is-glimm-transitioning');
                    controller.setBrightness(
                        document.documentElement.dataset.theme === 'dark' ? 1.26 : 1.48
                    );
                    let handle;
                    try {
                        handle = playSweep(controller, {
                            palette: options.palette ?? 'berry',
                            direction: options.direction ?? 'ltr',
                            sweepMs: options.sweepMs ?? 1320,
                            outroMs: options.outroMs ?? 860,
                            bandTight: options.bandTight ?? 0.78,
                            peakAlpha: options.peakAlpha ?? 1.16,
                            brightness:
                                options.brightness ??
                                (document.documentElement.dataset.theme === 'dark' ? 1.26 : 1.48),
                            waveAmount: options.waveAmount ?? 1.34,
                            rippleAmount: options.rippleAmount ?? 1.24,
                            waveSpeed: options.waveSpeed ?? 1.16,
                            swellAmount: options.swellAmount ?? 1.1,
                            onMidpoint: async () => {
                                await midpointAction?.();
                            },
                            onComplete: () => {
                                document.body.classList.remove('is-glimm-transitioning');
                                activeGlimmSweep = null;
                            },
                        });
                    } catch (error) {
                        glimmUnavailable = true;
                        glimmCanvas?.remove();
                        glimmCanvas = null;
                        glimmController = null;
                        return Promise.resolve(midpointAction?.()).finally(() => {
                            document.body.classList.remove('is-glimm-transitioning');
                            activeGlimmSweep = null;
                        });
                    }
                    activeGlimmSweep = handle;
                    return handle.done.finally(() => {
                        document.body.classList.remove('is-glimm-transitioning');
                    });
                };

                document.querySelectorAll('a, button').forEach((target) => {
                    target.classList.add('interactive-click');
                    target.addEventListener('pointerdown', () => {
                        target.classList.add('is-pressing');
                    });
                    ['pointerup', 'pointerleave', 'pointercancel', 'blur'].forEach((eventName) => {
                        target.addEventListener(eventName, () =>
                            target.classList.remove('is-pressing')
                        );
                    });
                });

                document.querySelectorAll('.theme-toggle, .lang-toggle').forEach((target) => {
                    target.addEventListener(
                        'click',
                        (event) => {
                            event.stopImmediatePropagation();
                            event.preventDefault();
                            target.classList.remove('is-pressing');
                            playGlimmSweep(() => {
                                if (target.classList.contains('theme-toggle')) {
                                    setTheme(
                                        document.documentElement.dataset.theme === 'dark'
                                            ? 'light'
                                            : 'dark'
                                    );
                                    return;
                                }
                                const nextLanguage =
                                    document.documentElement.lang === 'en' ? 'zh' : 'en';
                                setLanguage(nextLanguage);
                            });
                        },
                        true
                    );
                });

                const solverFrame = document.querySelector('.feature-component-frame');
                const solverCard = document.querySelector('.feature-component-card');
                if (solverFrame) {
                    syncFeatureDemoProgress(solverFrame, 0);
                    solverFrame.addEventListener('load', () => {
                        syncFeatureDemoProgress(
                            solverFrame,
                            featureProgressByFrame.get(solverFrame) ?? 0
                        );
                    });
                    window.addEventListener('message', (event) => {
                        if (getMessageType(event) === 'touchai-solver-ready') {
                            syncFeatureDemoProgress(
                                solverFrame,
                                featureProgressByFrame.get(solverFrame) ?? 0
                            );
                        }
                    });
                }

                const workOrganizerFrame = document.querySelector('.feature-work-frame');
                const workOrganizerCard = document.querySelector('.feature-work-card');
                if (workOrganizerFrame) {
                    syncFeatureDemoProgress(workOrganizerFrame, 0);
                    workOrganizerFrame.addEventListener('load', () => {
                        syncFeatureDemoProgress(
                            workOrganizerFrame,
                            featureProgressByFrame.get(workOrganizerFrame) ?? 0
                        );
                    });
                    window.addEventListener('message', (event) => {
                        if (getMessageType(event) === 'touchai-work-organizer-ready') {
                            syncFeatureDemoProgress(
                                workOrganizerFrame,
                                featureProgressByFrame.get(workOrganizerFrame) ?? 0
                            );
                        }
                    });
                }

                const reminderFrame = document.querySelector('.feature-reminder-frame');
                const reminderCard = document.querySelector('.feature-reminder-card');
                if (reminderFrame) {
                    syncFeatureDemoProgress(reminderFrame, 0);
                    reminderFrame.addEventListener('load', () => {
                        syncFeatureDemoProgress(
                            reminderFrame,
                            featureProgressByFrame.get(reminderFrame) ?? 0
                        );
                    });
                    window.addEventListener('message', (event) => {
                        if (getMessageType(event) === 'touchai-reminder-ready') {
                            syncFeatureDemoProgress(
                                reminderFrame,
                                featureProgressByFrame.get(reminderFrame) ?? 0
                            );
                        }
                    });
                }

                const replayEmbeddedComponent = async (frame) => {
                    const progress = featureProgressByFrame.get(frame) ?? 0;
                    await Promise.resolve(frame.reload?.());
                    syncFeatureDemoProgress(frame, progress);
                    window.setTimeout(() => syncFeatureDemoProgress(frame, progress), 120);
                    window.setTimeout(() => syncFeatureDemoProgress(frame, progress), 360);
                };

                const bindReplayCard = (card, frame, label) => {
                    if (!card || !frame) return;
                    let replaying = false;
                    card.setAttribute('role', 'button');
                    card.setAttribute('tabindex', '0');
                    card.setAttribute('aria-label', `${label}，点击刷新当前滚动进度`);

                    const replay = async () => {
                        if (replaying) return;
                        replaying = true;
                        try {
                            await replayEmbeddedComponent(frame);
                        } finally {
                            window.setTimeout(() => {
                                replaying = false;
                            }, 900);
                        }
                    };

                    card.addEventListener('click', (event) => {
                        if (event.target?.closest?.('button, a, input, textarea, select')) return;
                        replay();
                    });
                    card.addEventListener('keydown', (event) => {
                        if (event.key !== 'Enter' && event.key !== ' ') return;
                        event.preventDefault();
                        replay();
                    });
                };

                bindReplayCard(solverCard, solverFrame, '解题对话框');
                bindReplayCard(workOrganizerCard, workOrganizerFrame, '工作整理对话框');
                bindReplayCard(reminderCard, reminderFrame, '提醒对话框');

                const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

                gsap.utils.toArray('.hero, .section, .cta').forEach((section, index) => {
                    if (reduceMotion) {
                        gsap.set(section, { autoAlpha: 1, y: 0 });
                        return;
                    }

                    gsap.from(section, {
                        autoAlpha: 0,
                        y: 24,
                        duration: 0.8,
                        ease: 'power2.out',
                        scrollTrigger: {
                            trigger: section,
                            start: 'top 82%',
                            toggleActions: 'play none none reverse',
                        },
                    });
                });

                if (!reduceMotion) {
                    const workflowSection = document.querySelector('#workflow');
                    const scenarioCards = workflowSection
                        ? gsap.utils.toArray('#workflow .scenario-card')
                        : [];
                    const featureFrames = [solverFrame, workOrganizerFrame, reminderFrame].filter(
                        Boolean
                    );
                    const visualSection = document.querySelector('.visual-section');
                    const visualShell = document.querySelector('.visual-shell');
                    const introDemo = document.querySelector('.component-frame');
                    const compactFeatureViewportQuery = '(max-width: 900px)';
                    const shortDesktopViewportQuery =
                        '(min-width: 901px) and (max-height: 780px)';
                    const fullViewportQuery = '(min-width: 901px) and (min-height: 781px)';
                    const isShortDesktopViewport = () =>
                        window.innerWidth > 900 && window.innerHeight <= 780;
                    const getCompactStickyTop = () =>
                        window.innerWidth <= 560
                            ? 72
                            : Math.round(Math.min(Math.max(window.innerHeight * 0.1, 78), 112));
                    const getCompactIntroDistance = () =>
                        (() => {
                            const introHeight = introDemo?.getBoundingClientRect().height || 0;
                            if (isShortDesktopViewport()) {
                                return Math.round(
                                    Math.max(
                                        window.innerHeight * 2.8,
                                        introHeight * 4.2,
                                        1580
                                    )
                                );
                            }

                            return Math.round(
                                Math.max(
                                    window.innerHeight * (window.innerWidth <= 560 ? 0.82 : 1.02),
                                    introHeight * (window.innerWidth <= 560 ? 2.05 : 2.75),
                                    window.innerWidth <= 560 ? 620 : 960
                                )
                            );
                        })();
                    const getCompactFeatureStart = () =>
                        window.innerWidth <= 560 ? 'top 88%' : 'top 82%';
                    const getCompactFeatureEnd = () =>
                        window.innerWidth <= 560 ? 'bottom 22%' : 'bottom 28%';

                    const setupWorkflowPointerEffects = () => {
                        if (!workflowSection || !scenarioCards.length) return () => {};

                        const cleanups = scenarioCards.map((card) => {
                            const handlePointerMove = (event) => {
                                const rect = card.getBoundingClientRect();
                                const x = (event.clientX - rect.left) / rect.width;
                                const y = (event.clientY - rect.top) / rect.height;

                                gsap.to(card, {
                                    rotationY: gsap.utils.mapRange(0, 1, -7, 7, x),
                                    rotationX: gsap.utils.mapRange(0, 1, 7, -7, y),
                                    scale: 1.018,
                                    '--scenario-glow-x': `${x * 100}%`,
                                    '--scenario-glow-y': `${y * 100}%`,
                                    '--scenario-glow-opacity': 1,
                                    duration: 0.35,
                                    ease: 'power2.out',
                                    overwrite: 'auto',
                                });
                            };

                            const handlePointerEnter = () => {
                                gsap.fromTo(
                                    card,
                                    { '--scenario-glow-opacity': 0.2 },
                                    {
                                        '--scenario-glow-opacity': 1,
                                        duration: 0.25,
                                        ease: 'power2.out',
                                    }
                                );
                                gsap.fromTo(
                                    card,
                                    {
                                        '--scenario-shine-x': '-120%',
                                        '--scenario-shine-opacity': 0,
                                    },
                                    {
                                        '--scenario-shine-x': '120%',
                                        '--scenario-shine-opacity': 0.68,
                                        duration: 0.82,
                                        ease: 'power2.out',
                                        overwrite: 'auto',
                                        onComplete: () => {
                                            gsap.set(card, { '--scenario-shine-opacity': 0 });
                                        },
                                    }
                                );
                            };

                            const handlePointerLeave = () => {
                                gsap.to(card, {
                                    rotationX: 0,
                                    rotationY: 0,
                                    scale: 1,
                                    '--scenario-glow-opacity': 0,
                                    duration: 0.55,
                                    ease: 'power3.out',
                                    overwrite: 'auto',
                                });
                            };

                            card.addEventListener('pointermove', handlePointerMove);
                            card.addEventListener('pointerenter', handlePointerEnter);
                            card.addEventListener('pointerleave', handlePointerLeave);

                            return () => {
                                card.removeEventListener('pointermove', handlePointerMove);
                                card.removeEventListener('pointerenter', handlePointerEnter);
                                card.removeEventListener('pointerleave', handlePointerLeave);
                                gsap.set(card, {
                                    rotationX: 0,
                                    rotationY: 0,
                                    scale: 1,
                                    '--scenario-glow-opacity': 0,
                                    '--scenario-shine-opacity': 0,
                                });
                            };
                        });

                        return () => {
                            cleanups.forEach((cleanup) => cleanup());
                        };
                    };

                    const setupIntroScrollTrigger = (compact) => {
                        if (!visualSection || !visualShell || !introDemo) return () => {};

                        let isActive = true;
                        let componentTrigger;
                        const syncComponent = (progress) => {
                            queueDemoProgress(introDemo, 'touchai-set-progress', progress);
                        };
                        const refreshPinnedIntro = () => {
                            ScrollTrigger.refresh();
                            syncComponent(componentTrigger?.progress ?? 0);
                        };

                        const handleIntroReady = () => {
                            if (!isActive) return;
                            requestAnimationFrame(() => {
                                if (isActive) refreshPinnedIntro();
                            });
                        };
                        const handleReadyMessage = (event) => {
                            if (!isActive || getMessageType(event) !== 'touchai-component-ready') return;
                            requestAnimationFrame(() => {
                                if (isActive) refreshPinnedIntro();
                            });
                        };

                        gsap.set(visualShell, {
                            scale: 1,
                            transformOrigin: 'center center',
                        });

                        const timeline = gsap
                            .timeline({
                                scrollTrigger: {
                                    trigger: visualSection,
                                    start: () =>
                                        window.innerWidth > 900
                                            ? 'top top'
                                            : `top ${getCompactStickyTop()}px`,
                                    end: () =>
                                        window.innerWidth > 900
                                            ? 'bottom bottom'
                                            : `+=${getCompactIntroDistance()}`,
                                    pin: false,
                                    pinSpacing: false,
                                    scrub: compact ? 0.18 : 0.55,
                                    invalidateOnRefresh: true,
                                    onRefresh: (self) => {
                                        componentTrigger = self;
                                        gsap.set(visualShell, {
                                            scale: 1,
                                        });
                                        syncComponent(self.progress);
                                    },
                                    onEnter: () => syncComponent(componentTrigger?.progress ?? 0),
                                    onEnterBack: () =>
                                        syncComponent(componentTrigger?.progress ?? 1),
                                    onUpdate: (self) => {
                                        componentTrigger = self;
                                        syncComponent(self.progress);
                                    },
                                    onLeave: () => {
                                        syncComponent(1);
                                        queueDemoScrollIdle(introDemo);
                                    },
                                    onLeaveBack: () => {
                                        syncComponent(0);
                                        queueDemoScrollIdle(introDemo);
                                    },
                                },
                            })
                            .fromTo(
                                visualShell,
                                { y: 0, opacity: 0.65 },
                                { y: 0, opacity: 1, duration: 0.35, ease: 'power2.out' }
                            )
                            .to(introDemo, { opacity: 1, duration: 0.2, ease: 'none' }, 0);

                        introDemo.addEventListener('load', handleIntroReady);
                        introDemo.addEventListener('touchai-component-loaded', handleIntroReady);
                        window.addEventListener('message', handleReadyMessage);

                        return () => {
                            isActive = false;
                            introDemo.removeEventListener('load', handleIntroReady);
                            introDemo.removeEventListener(
                                'touchai-component-loaded',
                                handleIntroReady
                            );
                            window.removeEventListener('message', handleReadyMessage);
                            cancelQueuedDemoProgress(introDemo);
                            sendToDemo(introDemo, { type: 'touchai-clear-scroll-driven' });
                            timeline.scrollTrigger?.kill();
                            timeline.kill();
                        };
                    };

                    const setupFeatureScrollTriggers = (compact) => {
                        const triggers = featureFrames.map((frame) => {
                            const featureBlock = frame.closest('.feature-block') || frame;
                            const featureShell =
                                frame.closest('.feature-block-shell') || featureBlock;
                            let featureTrigger;
                            const getFeatureStickyTop = () => {
                                const shellHeight =
                                    featureShell.getBoundingClientRect().height || 560;
                                return Math.max(
                                    24,
                                    Math.round((window.innerHeight - shellHeight) / 2)
                                );
                            };
                            const syncCurrentFeatureProgress = () => {
                                syncFeatureDemoProgress(frame, featureTrigger?.progress ?? 0);
                            };

                            featureTrigger = ScrollTrigger.create({
                                trigger: featureBlock,
                                start: compact
                                    ? getCompactFeatureStart
                                    : () => {
                                          const viewportLead = Math.round(window.innerHeight * 0.92);
                                          return `top ${viewportLead}px`;
                                      },
                                end: compact
                                    ? getCompactFeatureEnd
                                    : () => {
                                          const blockHeight =
                                              featureBlock.getBoundingClientRect().height || 1500;
                                          const shellHeight =
                                              featureShell.getBoundingClientRect().height || 560;
                                          return `+=${Math.max(
                                              window.innerHeight * 1.35,
                                              blockHeight + shellHeight * 0.45
                                          )}`;
                                      },
                                pin: false,
                                pinSpacing: false,
                                anticipatePin: 0,
                                scrub: compact ? 0.16 : true,
                                invalidateOnRefresh: true,
                                onRefresh: syncCurrentFeatureProgress,
                                onEnter: syncCurrentFeatureProgress,
                                onEnterBack: syncCurrentFeatureProgress,
                                onUpdate: (self) => {
                                    syncFeatureDemoProgress(frame, self.progress);
                                },
                                onLeave: () => {
                                    syncFeatureDemoProgress(frame, 1);
                                },
                                onLeaveBack: () => {
                                    syncFeatureDemoProgress(frame, 0);
                                },
                            });

                            return featureTrigger;
                        });

                        return () => {
                            triggers.forEach((trigger, index) => {
                                trigger.kill();
                                const frame = featureFrames[index];
                                cancelQueuedDemoProgress(frame);
                                sendToDemo(frame, { type: 'touchai-clear-scroll-driven' });
                            });
                        };
                    };

                    const refreshScrollLayout = () => {
                        requestAnimationFrame(() => {
                            syncFeatureFrameSizing();
                            syncComponentBackground();
                            ScrollTrigger.refresh();
                        });
                    };

                    const scrollMatchMedia = gsap.matchMedia();
                    scrollMatchMedia.add(compactFeatureViewportQuery, () => {
                        const cleanupIntro = setupIntroScrollTrigger(true);
                        const cleanupFeatures = setupFeatureScrollTriggers(true);
                        refreshScrollLayout();

                        return () => {
                            cleanupIntro();
                            cleanupFeatures();
                        };
                    });
                    scrollMatchMedia.add(shortDesktopViewportQuery, () => {
                        const cleanupWorkflow = setupWorkflowPointerEffects();
                        const cleanupIntro = setupIntroScrollTrigger(true);
                        const cleanupFeatures = setupFeatureScrollTriggers(false);
                        refreshScrollLayout();

                        return () => {
                            cleanupWorkflow();
                            cleanupIntro();
                            cleanupFeatures();
                        };
                    });
                    scrollMatchMedia.add(fullViewportQuery, () => {
                        const cleanupWorkflow = setupWorkflowPointerEffects();
                        const cleanupIntro = setupIntroScrollTrigger(false);
                        const cleanupFeatures = setupFeatureScrollTriggers(false);
                        refreshScrollLayout();

                        return () => {
                            cleanupWorkflow();
                            cleanupIntro();
                            cleanupFeatures();
                        };
                    });
                }

                const nav = document.querySelector('.nav');
                const syncNavScrolled = () => {
                    nav?.classList.toggle('is-scrolled', window.scrollY > 12);
                };

                window.addEventListener('scroll', syncNavScrolled, { passive: true });

                let resizeTimer;
                window.addEventListener('resize', () => {
                    window.clearTimeout(resizeTimer);
                    resizeTimer = window.setTimeout(() => {
                        syncFeatureFrameSizing();
                        syncComponentBackground();
                        ScrollTrigger.refresh();
                    }, 120);
                });

                window.addEventListener('load', () => {
                    syncNavScrolled();
                    ScrollTrigger.refresh();
                });
            })();
        </script>
    </body>
</html>
